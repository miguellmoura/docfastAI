{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd apps/web && npm ci && npm run build",
  "outputDirectory": "apps/web/dist/docfast-web/browser",
  "devCommand": "cd apps/web && npm run start",
  "installCommand": "cd apps/web && npm ci",
  "framework": "angular",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
